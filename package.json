{
  "name": "expo-masonry-layout",
  "version": "1.1.5",
  "description": "High-performance masonry layout component for React Native and Expo applications",
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "react-native": "./lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.js",
      "react-native": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf lib",
    "prepublishOnly": "npm run clean && npm run build",
    "test": "jest",
    "lint": "standard",
    "lint:fix": "standard --fix"
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "react-native",
    "expo",
    "masonry",
    "layout",
    "grid",
    "virtualized",
    "performance"
  ],
  "author": "Echowaves Corp.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/echowaves/expo-masonry-layout.git"
  },
  "bugs": {
    "url": "https://github.com/echowaves/expo-masonry-layout/issues"
  },
  "homepage": "https://github.com/echowaves/expo-masonry-layout#readme",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.70.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/react": "18.2.0",
    "@types/react-native": "0.72.0",
    "jest": "29.7.0",
    "standard": "^17.1.2",
    "typescript": "5.7.2"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions"
  ]
}
